}

/* Função principal */
int main() {
    int opcao;

    do {
        printf("\n===== MENU =====\n");
        printf("1 - Equacao do 1º Grau( ax + b = 0)\n");
        printf("2 - Equacao do 2º Grau( ax² + bx + c = 0)\n");
        printf("3 - Sobre o Programa( Enzo Guilherme)\n");
        printf("0 - Sair\n");
        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);

        switch (opcao) {
            case 1:
                equacao_primeiro_grau();
                break;
            case 2:
                equacao_segundo_grau();
                break;
            case 3:
                sobre_programa();
                break;
            case 0:
                printf("Encerrando...\n");
                break;
            default:
                printf("Opcao invalida!\n");
        }

    } while (opcao != 0);

    return 0;
}
